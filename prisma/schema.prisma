generator client {
  provider = "prisma-client-js"
  // "native" = a plataforma que roda o `prisma generate` (runner do GitHub, dev local).
  // "rhel-openssl-3.0.x" = runtime serverless da Vercel — como buildamos FORA da
  // Vercel (no runner), o engine dela não vem sozinho e precisa ser gerado aqui.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Runtime: conexão pooled do Supabase (PgBouncer, porta 6543, ?pgbouncer=true).
  url       = env("DATABASE_URL")
  // Migrations: conexão DIRETA (porta 5432) — o Prisma Migrate não roda pelo
  // pooler em modo transaction. Ver .env.
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// Better Auth core tables
// ──────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?  @db.Text
  createdAt     DateTime
  updatedAt     DateTime

  sessions     Session[]
  accounts     Account[]
  userPokemons UserPokemon[]
  decks        Deck[]
  packState    PackState?
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime
  updatedAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime
}

// ──────────────────────────────────────────────
// Deck = loadouts do jogo NOVO (duelo tático 1×1) — Fase A.
//
// O jogo antigo (`UserCard`/`DeckCard`, simultâneo, 4 cartas fixas) foi CORTADO
// nesta fase (reset autorizado, F3). A coleção agora é `UserPokemon` (com
// nível/XP, ver abaixo) e o deck é uma lista de `DeckSlot`: cada slot é um
// loadout — 1 `UserPokemon` + 6 cartas (skills) escolhidas do learnset dele.
//
// 1×1 (F1): a batalha usa o slot ativo; o schema fica pronto pra time (até 6
// slots) numa fase futura. Ver PLANO_JOGO.md §5.
// ──────────────────────────────────────────────

model Deck {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Meu Deck")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots DeckSlot[]
}

// Um loadout do time: 1 UserPokemon + suas 6 cartas. `order` é a posição no
// time (0..5); no 1×1 só o slot ativo entra em campo.
model DeckSlot {
  id            String @id @default(cuid())
  deckId        String
  userPokemonId String
  order         Int

  deck        Deck           @relation(fields: [deckId], references: [id], onDelete: Cascade)
  userPokemon UserPokemon    @relation(fields: [userPokemonId], references: [id], onDelete: Cascade)
  cards       DeckSlotCard[]

  @@unique([deckId, order])
  @@unique([deckId, userPokemonId]) // um pokémon não ocupa dois slots do mesmo deck
}

// As 6 skills escolhidas do learnset do pokémon do slot. `order` é a posição na
// barra de golpes (0..5). A PK lógica é (deckSlotId, order) e (deckSlotId,
// moveId) — não dá pra repetir carta nem pular posição.
model DeckSlotCard {
  id         String @id @default(cuid())
  deckSlotId String
  moveId     String
  order      Int

  deckSlot DeckSlot @relation(fields: [deckSlotId], references: [id], onDelete: Cascade)
  move     Move     @relation(fields: [moveId], references: [id], onDelete: Cascade)

  @@unique([deckSlotId, order])
  @@unique([deckSlotId, moveId])
}

// ──────────────────────────────────────────────
// Espelho da PokéAPI (PLANO_JOGO.md §5 e §7) — Fase 0.
//
// Revertendo de propósito a decisão histórica de "nunca espelhar Pokémon":
// o duelo tático precisa CONSULTAR/FILTRAR por atributo (montar deck, listar
// learnset, ordenar por stat), coisa que o key-value cru de PokeApiCache não
// faz. As chaves de gestão são `pokemonApiId`/`moveApiId` (National Dex / move
// id da API) — identificam, deduplicam e guiam o refetch. `fetchedAt` diz o
// quão velho está o dado; o cron de refresh re-sincroniza o mais antigo.
//
// RLS: como toda tabela nova (AGENTS.md), estas nascem com RLS ligada na
// mesma migration — deny-all pra API PostgREST pública, transparente pro
// runtime (Prisma como `postgres`, dono + BYPASSRLS).
// ──────────────────────────────────────────────

model Pokemon {
  id             String   @id @default(cuid())
  pokemonApiId   Int      @unique // National Dex id — chave de refetch/dedup
  name           String
  types          Json // string[], ex: ["electric"]
  baseStats      Json // {hp,atk,def,spa,spd,spe} — base stats crus da API
  baseExperience Int? // quanto vale DERROTAR esta espécie (xpFromDefeat, fórmula da série)
  spriteUrl      String?  @db.Text
  fetchedAt      DateTime @default(now())

  // Evolução POR NÍVEL (pokedex/domain/evolution.ts). Só level-up com min_level
  // vira aresta; pedra/troca/amizade ficam null. O alvo é o pokemonApiId da
  // espécie nova — o awardBattleXp resolve pra Pokemon.id quando o nível bate.
  evolvesToApiId Int? // National Dex id da evolução por nível, ou null
  evolvesToLevel Int? // nível mínimo pra evoluir, ou null

  learnset     PokemonMove[]
  userPokemons UserPokemon[]
}

model Move {
  id          String   @id @default(cuid())
  moveApiId   Int      @unique
  name        String
  type        String
  power       Int?
  accuracy    Int?
  pp          Int
  priority    Int      @default(0)
  damageClass String // physical | special | status
  effect      Json? // efeitos estruturados (status, stat stage, etc.) — nulo por ora
  fetchedAt   DateTime @default(now())

  learnedBy    PokemonMove[]
  deckCards    DeckSlotCard[]
  unlockedByUsers UserPokemonMove[]
}

// Learnset (n:n) FIEL À SÉRIE: além do par, a linha carrega COMO a espécie
// aprende o move — o dado que a PokéAPI já dá em `version_group_details` e que
// o espelho jogava fora. É o que faz o nível LIBERAR cartas em vez de todo
// pokémon nascer sabendo tudo (ver pokedex/domain/learnset.ts).
//
// `versionGroup` é o jogo de referência escolhido pra ESPÉCIE (o mais recente
// em que ela aprende algo por level-up) — todas as linhas de um mesmo pokémon
// têm o mesmo valor. Guardado porque sem ele não dá pra auditar de onde veio o
// nível, nem trocar de geração depois sem re-seedar às cegas.
model PokemonMove {
  pokemonId      String
  moveId         String
  levelLearnedAt Int    @default(0) // 0 quando o método não é level-up
  learnMethod    String @default("level-up") // level-up | machine | egg | tutor
  versionGroup   String @default("") // ex: "scarlet-violet"

  pokemon Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)
  move    Move    @relation(fields: [moveId], references: [id], onDelete: Cascade)

  @@id([pokemonId, moveId])
  // O seletor de loadout lê "moves de level-up desta espécie, por nível" a cada
  // abertura do modal — é o filtro quente da montagem de deck.
  @@index([pokemonId, learnMethod, levelLearnedAt])
}

// ──────────────────────────────────────────────
// Coleção com nível incremental (PLANO_JOGO.md §5) — Fase 0.
// Cada instância nasce em STARTING_LEVEL e sobe com XP ganho em batalha; o
// nível deriva TODO stat de batalha (deriveStats) E libera quais moves do
// learnset viram carta (domain/learnset.ts).
//
// DUPLICATAS PERMITIDAS (decisão do dono): NÃO há mais `@@unique[userId,pokemonId]`.
// `UserPokemon` é uma tabela de INSTÂNCIAS — o jogador pode ter várias cópias da
// mesma espécie (pacote repetido cria uma nova; cruzamento faz nascer; troca
// transfere). O `id` cuid já é único. A corrida de ABERTURA de pacote continua
// fechada pelo claim do PackState (a unique daqui nunca guardou isso — só dava o
// "repetida = no-op"; ver packs/commands/openPack).
//
// `xp` é o TOTAL ACUMULADO (curva medium-fast: total pro nível n = n³), não o
// progresso dentro do nível. Assim `level` é uma FUNÇÃO de `xp`
// (levelFromXp) — os dois não têm como divergir, e não existe estado
// inconsistente pra reparar depois (não há worker pra reparar; CLAUDE.md §5).
// ──────────────────────────────────────────────

model UserPokemon {
  id         String   @id @default(cuid())
  userId     String
  pokemonId  String // espécie (Pokemon.id)
  level      Int      @default(1) // STARTING_LEVEL (pokedex/domain/leveling.ts)
  xp         Int      @default(1) // = xpForLevel(1); mantém level == levelFromXp(xp)
  capturedAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pokemon   Pokemon    @relation(fields: [pokemonId], references: [id])
  deckSlots DeckSlot[]
  unlockedMoves UserPokemonMove[]

  // Composto, mas NÃO único (duplicata permitida). É o mesmo índice do antigo
  // @@unique menos a unicidade: cobre `where userId` (prefixo à esquerda, ex.
  // getCollection) E `where userId+pokemonId` (o isNew do openPack, e o "já tem
  // a espécie X?" que troca/cruzamento vão usar). Trocar por só [userId] jogaria
  // fora a coluna pokemonId desses lookups.
  @@index([userId, pokemonId])
}

// Golpes desbloqueados POR FORA do nível (PLANO_JOGO §7.1 — TM/tutor/ovo).
// O learnset base (PokemonMove level-up) é da ESPÉCIE e derivado do nível; esta
// tabela guarda o que ESTE Pokémon do jogador aprendeu além disso. `source` diz
// como veio ("machine" = TM; "tutor"/"egg" nas próximas fatias). É o que faz o
// golpe virar carta jogável mesmo sem depender de nível.
//
// A regra combinada (level-up ∪ concedidos) mora em pokedex/domain/learnset
// (mergePlayableMoveIds) e é lida por pokedex/queries/getUnlockedMoveIds —
// consumida por deck (addToDeck/readLearnset) e battle (poda pós-evolução).
// @@unique([userPokemonId, moveId]): fecha o double-grant por construção (o
// claim otimista do token de TM conta com isso — CLAUDE.md regra 6).
model UserPokemonMove {
  id            String   @id @default(cuid())
  userPokemonId String
  moveId        String
  source        String // "machine" | "tutor" | "egg"
  grantedAt     DateTime @default(now())

  userPokemon UserPokemon @relation(fields: [userPokemonId], references: [id], onDelete: Cascade)
  move        Move        @relation(fields: [moveId], references: [id], onDelete: Cascade)

  @@unique([userPokemonId, moveId])
  @@index([userPokemonId])
}

// ──────────────────────────────────────────────
// Cache persistente de respostas da PokéAPI (pokémon/move/type nunca mudam
// pra uma geração já lançada — cache "eterno" entre invocações serverless)
// ──────────────────────────────────────────────

model PokeApiCache {
  key       String   @id // ex: "pokemon:25", "move:33", "type:4"
  payload   Json
  fetchedAt DateTime @default(now())
}

// ──────────────────────────────────────────────
// Duelo tático 1×1 por turnos SIMULTÂNEOS (PLANO_JOGO.md §3) — Fase A.
//
// Resolução por polling (resolve-na-leitura — sem worker no Vercel Hobby, ver
// CLAUDE.md regra 5). O estado de cada pokémon em partida é um snapshot
// congelado em JSON, montado uma única vez quando a partida começa (a partir do
// espelho local Pokemon/Move + o nível do UserPokemon) — depois disso a partida
// roda inteiramente sobre o nosso banco.
//
// SIMULTÂNEO, como a série: os dois jogadores escolhem a carta do mesmo `round`
// sem ver a do outro; quando as duas estão na mesa (ou o tempo estoura), o
// turno resolve e a ORDEM dentro dele é priority do move → Speed → sorteio
// (domain/turnOrder.ts). Não existe "de quem é a vez" — por isso `activeUserId`
// saiu do Battle. Cada jogador tem no máximo uma `BattleAction` por round
// (@@unique[battleId, round, userId]), e ela é SEGREDO até o turno resolver.
// ──────────────────────────────────────────────

enum BattleStatus {
  IN_PROGRESS
  FINISHED
  ABANDONED
}

model Battle {
  id            String       @id @default(cuid())
  status        BattleStatus @default(IN_PROGRESS)
  round         Int          @default(1)
  turnStartedAt DateTime     @default(now())
  winnerId      String?
  createdAt     DateTime     @default(now())
  finishedAt    DateTime?

  participants BattleParticipant[]
  turnLogs     BattleTurnLog[]
  actions      BattleAction[]
}

model BattleParticipant {
  id          String @id @default(cuid())
  battleId    String
  userId      String
  activeSlot  Int    @default(1)
  missedTurns Int    @default(0) // faltas (turno sem ação): +1 por timeout vencido, -1 por jogada. Chegou em MAX_MISSES => ABANDONED

  battle   Battle          @relation(fields: [battleId], references: [id], onDelete: Cascade)
  pokemons BattlePokemon[]

  @@unique([battleId, userId])
}

model BattlePokemon {
  id            String  @id @default(cuid())
  participantId String
  slot          Int
  // De onde este snapshot veio. NÃO é relação (o UserPokemon pode ser solto da
  // coleção no meio da partida e o snapshot tem que sobreviver — ele é
  // congelado de propósito). Serve pra creditar o XP no fim: sem isso não há
  // caminho de volta do combatente pro pokémon do jogador.
  userPokemonId String?
  pokemonId     Int
  name          String
  spriteUrl     String? @db.Text
  types         Json // string[]
  level         Int // vem de UserPokemon.level (não mais fixo em 50)
  stats         Json // {attack,defense,specialAttack,specialDefense,speed} — derivados por deriveStats(baseStats, level); hp fica em maxHp/currentHp
  maxHp         Int
  currentHp     Int
  fainted       Boolean @default(false)
  moves         Json // até 6 cartas: [{id,name,type,power,accuracy,damageClass,priority,maxPp,currentPp}]

  participant BattleParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, slot])
}

// O tipo de jogada de um round: usar um GOLPE ou TROCAR de pokémon (time de 6).
// Os dois são escolhas do MESMO round simultâneo — a troca voluntária resolve
// ANTES dos ataques (duelEngine.ts).
enum BattleActionType {
  MOVE
  SWITCH
}

// A jogada de um jogador no round atual — SEGREDO até o turno resolver. No
// simultâneo os DOIS têm uma linha por round (@@unique[battleId, round,
// userId]); quando as duas existem o turno resolve e ambas são apagadas. É por
// causa desta tabela que a linha crua do Battle nunca pode ir pro browser: ela
// entrega a jogada do oponente antes da resolução (CLAUDE.md regra 3).
model BattleAction {
  id        String           @id @default(cuid())
  battleId  String
  userId    String
  round     Int
  type      BattleActionType @default(MOVE)
  cardSlot  Int // MOVE: índice do golpe 0..5 | SWITCH: slot do pokémon alvo 1..6
  createdAt DateTime         @default(now())

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@unique([battleId, round, userId])
}

model BattleTurnLog {
  id         String   @id @default(cuid())
  battleId   String
  turnNumber Int
  events     Json
  createdAt  DateTime @default(now())

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@unique([battleId, turnNumber])
}

model MatchmakingQueueEntry {
  id         String   @id @default(cuid())
  userId     String   @unique
  deckId     String
  enqueuedAt DateTime @default(now())
}

// ──────────────────────────────────────────────
// Pacotes de cartas — a ÚNICA forma de obter pokémon (o "Capturar" direto
// morreu). Estado por jogador do cooldown diário + pacotes-bônus. Uma linha
// por usuário (userId é @id), pra o claim otimista do openPack caber num
// updateMany condicionado — sem worker, dois cliques no "Abrir" não podem dar
// dois pacotes (CLAUDE.md, regra 6).
// ──────────────────────────────────────────────

model PackState {
  userId         String    @id
  lastFreePackAt DateTime? // null = nunca abriu → 1º pacote disponível de cara (conta nova)
  extraPacks     Int       @default(0) // pacotes-bônus prontos pra abrir (recompensa de login)
  loginStreak    Int       @default(0)
  lastCheckIn    DateTime?
  tmTokens       Int       @default(0) // tokens de TM: gastos pra ensinar golpe `machine` (training/applyTM); ganhos no check-in diário

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
