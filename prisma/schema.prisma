generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime: conexão pooled do Supabase (PgBouncer, porta 6543, ?pgbouncer=true).
  url       = env("DATABASE_URL")
  // Migrations: conexão DIRETA (porta 5432) — o Prisma Migrate não roda pelo
  // pooler em modo transaction. Ver .env.
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// Better Auth core tables
// ──────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?  @db.Text
  createdAt     DateTime
  updatedAt     DateTime

  sessions     Session[]
  accounts     Account[]
  userCards    UserCard[]
  userPokemons UserPokemon[]
  decks        Deck[]
  packState    PackState?
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime
  updatedAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime
}

// ──────────────────────────────────────────────
// Game / user collection tables
//
// Dados de Pokémon (nome, sprite, stats, tipos, moves) NÃO são espelhados
// aqui — vêm sempre ao vivo da PokéAPI. `pokemonId` é só o id público da
// PokéAPI, salvo em texto plano (não há conteúdo protegido por direitos
// autorais em um inteiro sequencial, e criptografá-lo quebraria índice/unique
// sem nenhum ganho real).
// ──────────────────────────────────────────────

model UserCard {
  id        String   @id @default(cuid())
  userId    String
  pokemonId Int
  addedAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deckCards DeckCard[]

  @@unique([userId, pokemonId])
}

model Deck {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Meu Deck")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deckCards DeckCard[]
}

model DeckCard {
  id         String   @id @default(cuid())
  deckId     String
  userCardId String
  addedAt    DateTime @default(now())

  deck     Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  userCard UserCard @relation(fields: [userCardId], references: [id], onDelete: Cascade)

  @@unique([deckId, userCardId])
}

// ──────────────────────────────────────────────
// Espelho da PokéAPI (PLANO_JOGO.md §5 e §7) — Fase 0.
//
// Revertendo de propósito a decisão histórica de "nunca espelhar Pokémon":
// o duelo tático precisa CONSULTAR/FILTRAR por atributo (montar deck, listar
// learnset, ordenar por stat), coisa que o key-value cru de PokeApiCache não
// faz. As chaves de gestão são `pokemonApiId`/`moveApiId` (National Dex / move
// id da API) — identificam, deduplicam e guiam o refetch. `fetchedAt` diz o
// quão velho está o dado; o cron de refresh re-sincroniza o mais antigo.
//
// RLS: como toda tabela nova (AGENTS.md), estas nascem com RLS ligada na
// mesma migration — deny-all pra API PostgREST pública, transparente pro
// runtime (Prisma como `postgres`, dono + BYPASSRLS).
// ──────────────────────────────────────────────

model Pokemon {
  id           String   @id @default(cuid())
  pokemonApiId Int      @unique // National Dex id — chave de refetch/dedup
  name         String
  types        Json // string[], ex: ["electric"]
  baseStats    Json // {hp,atk,def,spa,spd,spe} — base stats crus da API
  spriteUrl    String?  @db.Text
  fetchedAt    DateTime @default(now())

  learnset     PokemonMove[]
  userPokemons UserPokemon[]
}

model Move {
  id          String   @id @default(cuid())
  moveApiId   Int      @unique
  name        String
  type        String
  power       Int?
  accuracy    Int?
  pp          Int
  priority    Int      @default(0)
  damageClass String // physical | special | status
  effect      Json? // efeitos estruturados (status, stat stage, etc.) — nulo por ora
  fetchedAt   DateTime @default(now())

  learnedBy PokemonMove[]
}

// Learnset (n:n): todo Pokémon tem acesso ao learnset inteiro que a API
// devolve (PLANO_JOGO.md §1). A PK composta é o próprio par, então o upsert
// do sync é idempotente por (pokemonId, moveId).
model PokemonMove {
  pokemonId String
  moveId    String

  pokemon Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)
  move    Move    @relation(fields: [moveId], references: [id], onDelete: Cascade)

  @@id([pokemonId, moveId])
}

// ──────────────────────────────────────────────
// Coleção com nível incremental (PLANO_JOGO.md §5) — Fase 0.
// Substitui, no jogo novo, o `UserCard` (que segue vivo pro jogo atual até a
// Fase A migrar a batalha). Cada instância nasce nível 1 e sobe com XP; o
// nível deriva TODO stat de batalha via a fórmula da série (domain/leveling).
// @@unique([userId, pokemonId]): 1 instância por espécie — fecha a corrida de
// captura por construção (CLAUDE.md regra 6), como já faz UserCard.
// ──────────────────────────────────────────────

model UserPokemon {
  id         String   @id @default(cuid())
  userId     String
  pokemonId  String // espécie (Pokemon.id)
  level      Int      @default(1)
  xp         Int      @default(0)
  capturedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pokemon Pokemon @relation(fields: [pokemonId], references: [id])

  @@unique([userId, pokemonId])
}

// ──────────────────────────────────────────────
// Cache persistente de respostas da PokéAPI (pokémon/move/type nunca mudam
// pra uma geração já lançada — cache "eterno" entre invocações serverless)
// ──────────────────────────────────────────────

model PokeApiCache {
  key       String   @id // ex: "pokemon:25", "move:33", "type:4"
  payload   Json
  fetchedAt DateTime @default(now())
}

// ──────────────────────────────────────────────
// Batalha PvP assíncrona (times via Deck, resolução por polling — sem
// WebSocket, pra caber em deploy serverless padrão). Estado de cada
// pokémon em partida é um snapshot congelado em JSON, montado uma única
// vez a partir da PokéAPI quando a partida começa — depois disso a
// partida roda inteiramente sobre o nosso banco.
// ──────────────────────────────────────────────

enum BattleStatus {
  IN_PROGRESS
  FINISHED
  ABANDONED
}

enum BattleActionType {
  MOVE
  SWITCH
}

model Battle {
  id            String       @id @default(cuid())
  status        BattleStatus @default(IN_PROGRESS)
  currentTurn   Int          @default(1)
  turnStartedAt DateTime     @default(now())
  winnerId      String?
  createdAt     DateTime     @default(now())
  finishedAt    DateTime?

  participants BattleParticipant[]
  turnLogs     BattleTurnLog[]
  pendingMoves BattlePendingMove[]
}

model BattleParticipant {
  id          String @id @default(cuid())
  battleId    String
  userId      String
  activeSlot  Int    @default(1)
  missedTurns Int    @default(0) // faltas (turno sem ação): +1 por timeout vencido, -1 por jogada. Chegou em MAX_MISSES => ABANDONED

  battle   Battle          @relation(fields: [battleId], references: [id], onDelete: Cascade)
  pokemons BattlePokemon[]

  @@unique([battleId, userId])
}

model BattlePokemon {
  id            String  @id @default(cuid())
  participantId String
  slot          Int
  pokemonId     Int
  name          String
  spriteUrl     String? @db.Text
  types         Json // string[]
  level         Int     @default(50)
  stats         Json // {attack,defense,specialAttack,specialDefense,speed} — hp fica em maxHp/currentHp
  maxHp         Int
  currentHp     Int
  fainted       Boolean @default(false)
  moves         Json // até 4: [{id,name,type,power,accuracy,damageClass,priority,maxPp,currentPp}]

  participant BattleParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, slot])
}

model BattlePendingMove {
  id           String           @id @default(cuid())
  battleId     String
  userId       String
  turnNumber   Int
  actionType   BattleActionType
  moveSlot     Int?
  switchToSlot Int?
  submittedAt  DateTime         @default(now())

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@unique([battleId, userId, turnNumber])
}

model BattleTurnLog {
  id         String   @id @default(cuid())
  battleId   String
  turnNumber Int
  events     Json
  createdAt  DateTime @default(now())

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@unique([battleId, turnNumber])
}

model MatchmakingQueueEntry {
  id         String   @id @default(cuid())
  userId     String   @unique
  deckId     String
  enqueuedAt DateTime @default(now())
}

// ──────────────────────────────────────────────
// Pacotes de cartas — a ÚNICA forma de obter pokémon (o "Capturar" direto
// morreu). Estado por jogador do cooldown diário + pacotes-bônus. Uma linha
// por usuário (userId é @id), pra o claim otimista do openPack caber num
// updateMany condicionado — sem worker, dois cliques no "Abrir" não podem dar
// dois pacotes (CLAUDE.md, regra 6).
// ──────────────────────────────────────────────

model PackState {
  userId         String    @id
  lastFreePackAt DateTime? // null = nunca abriu → 1º pacote disponível de cara (conta nova)
  extraPacks     Int       @default(0) // pacotes-bônus prontos pra abrir (recompensa de login)
  loginStreak    Int       @default(0)
  lastCheckIn    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
